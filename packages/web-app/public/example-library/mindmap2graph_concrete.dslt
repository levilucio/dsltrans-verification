    }
}

// Expected to FAIL
property NodeMapsToTargetEdge_ShouldFail {
    precondition {
        any sm : MindMapModel
        any sn : Topic
        direct l1 : nodes -- sm.sn
    }
    postcondition {
        te : Arc
        te <--trace-- sn
    }
}

property NodeMapsToTargetModel_ShouldFail {
    precondition {
        any sm : MindMapModel
        any sn : Topic
        direct l1 : nodes -- sm.sn
    }
    postcondition {
        tm : GraphModel
        tm <--trace-- sn
    }
}

