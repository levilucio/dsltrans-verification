// Expected to FAIL
property NodeMapsToTargetEdge_ShouldFail {
    precondition {
        any sm : WorkflowModel
        any sn : Task
        direct l1 : nodes -- sm.sn
    }
    postcondition {
        te : Arc
        te <--trace-- sn
    }
}

