// Expected to FAIL
property NodeMapsToTargetEdge_ShouldFail {
    precondition {
        any sm : OrgModel
        any sn : Role
        direct l1 : nodes -- sm.sn
    }
    postcondition {
        te : Grant
        te <--trace-- sn
    }
}

property NodeMapsToTargetModel_ShouldFail {
    precondition {
        any sm : OrgModel
        any sn : Role
        direct l1 : nodes -- sm.sn
    }
    postcondition {
        tm : AclModel
        tm <--trace-- sn
    }
}

