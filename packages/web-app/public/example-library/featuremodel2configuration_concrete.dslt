    precondition {
        any sm : FeatureRoot
        any sn1 : Feature
        any sn2 : Feature
        any se : Requires
        direct l1 : nodes -- sm.sn1
        direct l2 : nodes -- sm.sn2
        direct eL : edges -- sm.se
