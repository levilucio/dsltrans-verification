// Expected to FAIL
property NodeMapsToTargetEdge_ShouldFail {
    precondition {
        any sm : FeatureRoot
        any sn : Feature
        direct l1 : nodes -- sm.sn
    }
    postcondition {
        te : Constraint
        te <--trace-- sn
    }
}

property NodeMapsToTargetModel_ShouldFail {
    precondition {
        any sm : FeatureRoot
        any sn : Feature
