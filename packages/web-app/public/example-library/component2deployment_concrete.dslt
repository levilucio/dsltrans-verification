}

// Expected to FAIL
property NodeMapsToTargetEdge_ShouldFail {
    precondition {
        any sm : ComponentModel
        any sn : ComponentNode
        direct l1 : nodes -- sm.sn
    }
    postcondition {
        te : Connector
        te <--trace-- sn
    }
}

property NodeMapsToTargetModel_ShouldFail {
    precondition {
        any sm : ComponentModel
        any sn : ComponentNode
        direct l1 : nodes -- sm.sn
    }
    postcondition {
        tm : DeploymentModel
        tm <--trace-- sn
    }
}

property EdgeMapsToTargetNode_ShouldFail {
    precondition {
        any sm : ComponentModel
        any se : Dependency
        any sn1 : ComponentNode
        any sn2 : ComponentNode
        direct eL : edges -- sm.se
        direct sL : src -- se.sn1
        direct dL : dst -- se.sn2
    }
    postcondition {
        tn : Node
        tn <--trace-- se
    }
}

