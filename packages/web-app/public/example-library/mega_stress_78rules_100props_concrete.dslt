metamodel MegaSource {
    enum Kind { K0, K1, K2 }
    class MegaModel { }
    class A { flag: Bool level: Int kind: Kind }
    class B { flag: Bool level: Int kind: Kind }
    class C { flag: Bool level: Int kind: Kind }
    class Group { flag: Bool level: Int }
    class RelAB { weight: Int }
    class RelBC { weight: Int }
    class RelCA { weight: Int }
    class Membership { strength: Int }

    containment assoc aNodes : MegaModel[1] -- A[0..*]
    containment assoc bs : MegaModel[1] -- B[0..*]
    containment assoc cs : MegaModel[1] -- C[0..*]
    containment assoc groups : MegaModel[1] -- Group[0..*]
    containment assoc relabs : MegaModel[1] -- RelAB[0..*]
    containment assoc relbcs : MegaModel[1] -- RelBC[0..*]
    containment assoc relcas : MegaModel[1] -- RelCA[0..*]
    containment assoc memberships : MegaModel[1] -- Membership[0..*]

    assoc abSrc : RelAB[0..*] -- A[1]
    assoc abDst : RelAB[0..*] -- B[1]
    assoc bcSrc : RelBC[0..*] -- B[1]
    assoc bcDst : RelBC[0..*] -- C[1]
    assoc caSrc : RelCA[0..*] -- C[1]
    assoc caDst : RelCA[0..*] -- A[1]

    assoc memberGroup : Membership[0..*] -- Group[1]
    assoc memberA : Membership[0..*] -- A[0..1]
    assoc memberB : Membership[0..*] -- B[0..1]
    assoc memberC : Membership[0..*] -- C[0..1]
}

metamodel MegaTarget {
    class TMegaModel { }
    class TA { }
    class TB { }
    class TC { }
    class TGroup { }
    class TLinkAB { }
    class TLinkBC { }
    class TLinkCA { }
    abstract class Marker { }
    class Marker01 extends Marker { }
    class Marker02 extends Marker { }
    class Marker03 extends Marker { }
    class Marker04 extends Marker { }
    class Marker05 extends Marker { }
    class Marker06 extends Marker { }
    class Marker07 extends Marker { }
    class Marker08 extends Marker { }
    class Marker09 extends Marker { }
    class Marker10 extends Marker { }
    class Marker11 extends Marker { }
    class Marker12 extends Marker { }
    class Marker13 extends Marker { }
    class Marker14 extends Marker { }
    class Marker15 extends Marker { }
    class Marker16 extends Marker { }
    class Marker17 extends Marker { }
    class Marker18 extends Marker { }
    class Marker19 extends Marker { }
    class Marker20 extends Marker { }
    class Marker21 extends Marker { }
    class Marker22 extends Marker { }
    class Marker23 extends Marker { }
    class Marker24 extends Marker { }
    class Marker25 extends Marker { }
    class Marker26 extends Marker { }
    class Marker27 extends Marker { }
    class Marker28 extends Marker { }
    class Marker29 extends Marker { }
    class Marker30 extends Marker { }
    class Marker31 extends Marker { }
    class Marker32 extends Marker { }
    class Marker33 extends Marker { }
    class Marker34 extends Marker { }
    class Marker35 extends Marker { }
    class Marker36 extends Marker { }
    class Marker37 extends Marker { }
    class Marker38 extends Marker { }
    class Marker39 extends Marker { }
    class Marker40 extends Marker { }
    class Marker41 extends Marker { }
    class Marker42 extends Marker { }
    class Marker43 extends Marker { }
    class Marker44 extends Marker { }
    class Marker45 extends Marker { }
    class Marker46 extends Marker { }
    class Marker47 extends Marker { }
    class Marker48 extends Marker { }
    class Marker49 extends Marker { }
    class Marker50 extends Marker { }
    class Marker51 extends Marker { }
    class Marker52 extends Marker { }
    class Marker53 extends Marker { }
    class Marker54 extends Marker { }
    class Marker55 extends Marker { }
    class Marker56 extends Marker { }
    class Marker57 extends Marker { }
    class Marker58 extends Marker { }
    class Marker59 extends Marker { }
    class Marker60 extends Marker { }

    containment assoc tas : TMegaModel[1] -- TA[0..*]
    containment assoc tbs : TMegaModel[1] -- TB[0..*]
    containment assoc tcs : TMegaModel[1] -- TC[0..*]
    containment assoc tgroups : TMegaModel[1] -- TGroup[0..*]
    containment assoc tabLinks : TMegaModel[1] -- TLinkAB[0..*]
    containment assoc tbcLinks : TMegaModel[1] -- TLinkBC[0..*]
    containment assoc tcaLinks : TMegaModel[1] -- TLinkCA[0..*]
    containment assoc markers : TMegaModel[1] -- Marker[0..*]

    assoc tabSrc : TLinkAB[0..*] -- TA[1]
    assoc tabDst : TLinkAB[0..*] -- TB[1]
    assoc tbcSrc : TLinkBC[0..*] -- TB[1]
    assoc tbcDst : TLinkBC[0..*] -- TC[1]
    assoc tcaSrc : TLinkCA[0..*] -- TC[1]
    assoc tcaDst : TLinkCA[0..*] -- TA[1]

    assoc groupA : TGroup[0..*] -- TA[0..*]
    assoc groupB : TGroup[0..*] -- TB[0..*]
    assoc groupC : TGroup[0..*] -- TC[0..*]

    assoc markerA : Marker[0..*] -- TA[0..1]
    assoc markerB : Marker[0..*] -- TB[0..1]
    assoc markerC : Marker[0..*] -- TC[0..1]
}

transformation MegaStressTransform : MegaSource -> MegaTarget {
    layer L1_CreateBase {
        rule Model2TMegaModel {
            match {
                any m : MegaModel
            }
            apply {
                tm : TMegaModel
            }
        }
        rule A2TA {
            match {
                any a : A
            }
            apply {
                ta : TA
            }
        }
        rule B2TB {
            match {
                any b : B
            }
            apply {
                tb : TB
            }
        }
        rule C2TC {
            match {
                any c : C
            }
            apply {
                tc : TC
            }
        }
        rule Group2TGroup {
            match {
                any g : Group
            }
            apply {
                tg : TGroup
            }
        }
        rule RelAB2TLinkAB {
            match {
                any r : RelAB
            }
            apply {
                tr : TLinkAB
            }
        }
        rule RelBC2TLinkBC {
            match {
                any r : RelBC
            }
            apply {
                tr : TLinkBC
            }
        }
        rule RelCA2TLinkCA {
            match {
                any r : RelCA
            }
            apply {
                tr : TLinkCA
            }
        }
    }

    layer L2_ConnectBase {
        rule ConnectTAInModel {
            match {
                any m : MegaModel
                any a : A
                direct l : aNodes -- m.a
            }
            apply {
                tm : TMegaModel
                ta : TA
                o : tas -- tm.ta
            }
            backward {
                tm <--trace-- m
                ta <--trace-- a
            }
        }
        rule ConnectTBInModel {
            match {
                any m : MegaModel
                any b : B
                direct l : bs -- m.b
            }
            apply {
                tm : TMegaModel
                tb : TB
                o : tbs -- tm.tb
            }
            backward {
                tm <--trace-- m
                tb <--trace-- b
            }
        }
        rule ConnectTCInModel {
            match {
                any m : MegaModel
                any c : C
                direct l : cs -- m.c
            }
            apply {
                tm : TMegaModel
                tc : TC
                o : tcs -- tm.tc
            }
            backward {
                tm <--trace-- m
                tc <--trace-- c
            }
        }
        rule ConnectTGroupInModel {
            match {
                any m : MegaModel
                any g : Group
                direct l : groups -- m.g
            }
            apply {
                tm : TMegaModel
                tg : TGroup
                o : tgroups -- tm.tg
            }
            backward {
                tm <--trace-- m
                tg <--trace-- g
            }
        }
        rule ConnectAB {
            match {
                any m : MegaModel
                any r : RelAB
                any a : A
                any b : B
                direct rl : relabs -- m.r
                direct s : abSrc -- r.a
                direct d : abDst -- r.b
            }
            apply {
                tm : TMegaModel
                tr : TLinkAB
                ta : TA
                tb : TB
                o1 : tabLinks -- tm.tr
                o2 : tabSrc -- tr.ta
                o3 : tabDst -- tr.tb
            }
            backward {
                tm <--trace-- m
                tr <--trace-- r
                ta <--trace-- a
                tb <--trace-- b
            }
        }
        rule ConnectBC {
            match {
                any m : MegaModel
                any r : RelBC
                any b : B
                any c : C
                direct rl : relbcs -- m.r
                direct s : bcSrc -- r.b
                direct d : bcDst -- r.c
            }
            apply {
                tm : TMegaModel
                tr : TLinkBC
                tb : TB
                tc : TC
                o1 : tbcLinks -- tm.tr
                o2 : tbcSrc -- tr.tb
                o3 : tbcDst -- tr.tc
            }
            backward {
                tm <--trace-- m
                tr <--trace-- r
                tb <--trace-- b
                tc <--trace-- c
            }
        }
        rule ConnectCA {
            match {
                any m : MegaModel
                any r : RelCA
                any c : C
                any a : A
                direct rl : relcas -- m.r
                direct s : caSrc -- r.c
                direct d : caDst -- r.a
            }
            apply {
                tm : TMegaModel
                tr : TLinkCA
                tc : TC
                ta : TA
                o1 : tcaLinks -- tm.tr
                o2 : tcaSrc -- tr.tc
                o3 : tcaDst -- tr.ta
            }
            backward {
                tm <--trace-- m
                tr <--trace-- r
                tc <--trace-- c
                ta <--trace-- a
            }
        }
        rule ConnectGroupA {
            match {
                any ms : Membership
                any g : Group
                any a : A
                direct gL : memberGroup -- ms.g
                direct aL : memberA -- ms.a
            }
            apply {
                tg : TGroup
                ta : TA
                l : groupA -- tg.ta
            }
            backward {
                tg <--trace-- g
                ta <--trace-- a
            }
        }
        rule ConnectGroupB {
            match {
                any ms : Membership
                any g : Group
                any b : B
                direct gL : memberGroup -- ms.g
                direct bL : memberB -- ms.b
            }
            apply {
                tg : TGroup
                tb : TB
                l : groupB -- tg.tb
            }
            backward {
                tg <--trace-- g
                tb <--trace-- b
            }
        }
        rule ConnectGroupC {
            match {
                any ms : Membership
                any g : Group
                any c : C
                direct gL : memberGroup -- ms.g
                direct cL : memberC -- ms.c
            }
            apply {
                tg : TGroup
                tc : TC
                l : groupC -- tg.tc
            }
            backward {
                tg <--trace-- g
                tc <--trace-- c
            }
        }
    }

    layer L3_Markers {
        rule Mk01_A {
            match {
                any m : MegaModel
                any a : A where a.flag == true
                direct l : aNodes -- m.a
            }
            apply {
                tm : TMegaModel
                ta : TA
                mk : Marker01
                l1 : markers -- tm.mk
                l2 : markerA -- mk.ta
            }
            backward {
                tm <--trace-- m
                ta <--trace-- a
            }
        }
        rule Mk02_A {
            match {
                any m : MegaModel
                any a : A where a.level >= 1
                direct l : aNodes -- m.a
            }
            apply {
                tm : TMegaModel
                ta : TA
                mk : Marker02
                l1 : markers -- tm.mk
                l2 : markerA -- mk.ta
            }
            backward {
                tm <--trace-- m
                ta <--trace-- a
            }
        }
        rule Mk03_A {
            match {
                any m : MegaModel
                any a : A where a.kind == "K1"
                direct l : aNodes -- m.a
            }
            apply {
                tm : TMegaModel
                ta : TA
                mk : Marker03
                l1 : markers -- tm.mk
                l2 : markerA -- mk.ta
            }
            backward {
                tm <--trace-- m
                ta <--trace-- a
            }
        }
        rule Mk04_A {
            match {
                any m : MegaModel
                any a : A
                direct l : aNodes -- m.a
            }
            apply {
                tm : TMegaModel
                ta : TA
                mk : Marker04
                l1 : markers -- tm.mk
                l2 : markerA -- mk.ta
            }
            backward {
                tm <--trace-- m
                ta <--trace-- a
            }
        }
        rule Mk05_A {
            match {
                any m : MegaModel
                any a : A where a.flag == true
                direct l : aNodes -- m.a
            }
            apply {
                tm : TMegaModel
                ta : TA
                mk : Marker05
                l1 : markers -- tm.mk
                l2 : markerA -- mk.ta
            }
            backward {
                tm <--trace-- m
                ta <--trace-- a
            }
        }
        rule Mk06_A {
            match {
                any m : MegaModel
                any a : A where a.level >= 1
                direct l : aNodes -- m.a
            }
            apply {
                tm : TMegaModel
                ta : TA
                mk : Marker06
                l1 : markers -- tm.mk
                l2 : markerA -- mk.ta
            }
            backward {
                tm <--trace-- m
                ta <--trace-- a
            }
        }
        rule Mk07_A {
            match {
                any m : MegaModel
                any a : A where a.kind == "K1"
                direct l : aNodes -- m.a
            }
            apply {
                tm : TMegaModel
