// Expected to HOLD
property ModelMaps {
    precondition { any m : MegaModel }
    postcondition { tm : TMegaModel tm <--trace-- m }
}
property AMaps {
    precondition { any a : A }
    postcondition { ta : TA ta <--trace-- a }
}
property BMaps {
    precondition { any b : B }
    postcondition { tb : TB tb <--trace-- b }
}
property CMaps {
    precondition { any c : C }
    postcondition { tc : TC tc <--trace-- c }
}
property GroupMaps {
    precondition { any g : Group }
    postcondition { tg : TGroup tg <--trace-- g }
}
property RelABMaps {
    precondition { any r : RelAB }
    postcondition { tr : TLinkAB tr <--trace-- r }
}
property RelBCMaps {
    precondition { any r : RelBC }
    postcondition { tr : TLinkBC tr <--trace-- r }
}
property RelCAMaps {
    precondition { any r : RelCA }
    postcondition { tr : TLinkCA tr <--trace-- r }
}
property GroupAConnectionPreserved {
    precondition {
        any ms : Membership
        any g : Group
        any a : A
        direct gL : memberGroup -- ms.g
        direct aL : memberA -- ms.a
    }
    postcondition {
        tg : TGroup
        ta : TA
        l : groupA -- tg.ta
        tg <--trace-- g
        ta <--trace-- a
    }
}
property ABConnectionPreserved {
    precondition {
        any m : MegaModel
        any r : RelAB
        any a : A
        any b : B
        direct rl : relabs -- m.r
        direct s : abSrc -- r.a
        direct d : abDst -- r.b
    }
    postcondition {
        tr : TLinkAB
        ta : TA
        tb : TB
        l1 : tabSrc -- tr.ta
        l2 : tabDst -- tr.tb
        tr <--trace-- r
        ta <--trace-- a
        tb <--trace-- b
    }
}
