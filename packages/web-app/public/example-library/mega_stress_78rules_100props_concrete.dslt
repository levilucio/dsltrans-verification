                direct l : aNodes -- m.a
            }
            apply {
                tm : TMegaModel
                ta : TA
                mk : Marker08
                l1 : markers -- tm.mk
                l2 : markerA -- mk.ta
            }
            backward {
                tm <--trace-- m
                ta <--trace-- a
            }
        }
        rule Mk09_A {
            match {
                any m : MegaModel
                any a : A where a.flag == true
                direct l : aNodes -- m.a
            }
            apply {
                tm : TMegaModel
                ta : TA
                mk : Marker09
                l1 : markers -- tm.mk
                l2 : markerA -- mk.ta
            }
            backward {
                tm <--trace-- m
                ta <--trace-- a
            }
        }
        rule Mk10_A {
            match {
