// Properties: core traces (expected HOLDS)
property ModelHasModel { precondition { any m : Model } postcondition { outM : Model outM <--trace-- m } }
property PkgHasPkg { precondition { any p : Pkg } postcondition { outP : Pkg outP <--trace-- p } }
property E1HasT1 { precondition { any e : E1 } postcondition { t : T1 t <--trace-- e } }
property E2HasT2 { precondition { any e : E2 } postcondition { t : T2 t <--trace-- e } }
property E3HasT3 { precondition { any e : E3 } postcondition { t : T3 t <--trace-- e } }
property E4HasT4 { precondition { any e : E4 } postcondition { t : T4 t <--trace-- e } }
property E5HasT5 { precondition { any e : E5 } postcondition { t : T5 t <--trace-- e } }
property E6HasT6 { precondition { any e : E6 } postcondition { t : T6 t <--trace-- e } }
property E7HasT7 { precondition { any e : E7 } postcondition { t : T7 t <--trace-- e } }
property E8HasT8 { precondition { any e : E8 } postcondition { t : T8 t <--trace-- e } }
property E9HasT9 { precondition { any e : E9 } postcondition { t : T9 t <--trace-- e } }
property E10HasT10 { precondition { any e : E10 } postcondition { t : T10 t <--trace-- e } }
property E11HasT11 { precondition { any e : E11 } postcondition { t : T11 t <--trace-- e } }
property E12HasT12 { precondition { any e : E12 } postcondition { t : T12 t <--trace-- e } }
property E13HasT13 { precondition { any e : E13 } postcondition { t : T13 t <--trace-- e } }
// Expected VIOLATED (wrong trace targets)
property E1TracedToT2_ShouldFail { precondition { any e : E1 } postcondition { t : T2 t <--trace-- e } }
property PkgTracedToT1_ShouldFail { precondition { any p : Pkg } postcondition { t : T1 t <--trace-- p } }



