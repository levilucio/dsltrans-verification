        rule E7_2_T7_Cond { match { any e : E7 where e.tag == "a" } apply { t : T7 { tag = "a" } } }
    }
    layer MapE8 {
        rule E8_2_T8 { match { any e : E8 } apply { t : T8 } }
        rule E8_2_T8_Tagged { match { any e : E8 where e.tag != "" } apply { t : T8 { tag = e.tag } } }
        rule E8_2_T8_InPkg { match { any p : Pkg
                any e : E8
