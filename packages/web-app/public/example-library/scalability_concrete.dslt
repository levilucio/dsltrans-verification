                direct r : root -- m.p
                direct pe : pkgE4 -- p.e }
            apply { outM : Model
                outP : Pkg
                t : T4
                outR : root -- outM.outP
                outPe : pkgT4 -- outP.t }
        }
        rule E4_2_T4_Cond { match { any e : E4 where e.tag == "a" } apply { t : T4 { tag = "a" } } }
    }
    layer MapE5 {
        rule E5_2_T5 { match { any e : E5 } apply { t : T5 } }
        rule E5_2_T5_Tagged { match { any e : E5 where e.tag != "" } apply { t : T5 { tag = e.tag } } }
        rule E5_2_T5_InPkg { match { any p : Pkg
                any e : E5
                direct l : pkgE5 -- p.e } apply { outP : Pkg
                t : T5
                outL : pkgT5 -- outP.t } }
        rule E5_2_T5_Linked { match { any m : Model
                any p : Pkg
                any e : E5
                direct r : root -- m.p
                direct pe : pkgE5 -- p.e } apply { outM : Model
                outP : Pkg
                t : T5
                outR : root -- outM.outP
                outPe : pkgT5 -- outP.t } }
        rule E5_2_T5_Cond { match { any e : E5 where e.tag == "a" } apply { t : T5 { tag = "a" } } }
    }
    layer MapE6 {
        rule E6_2_T6 { match { any e : E6 } apply { t : T6 } }
        rule E6_2_T6_Tagged { match { any e : E6 where e.tag != "" } apply { t : T6 { tag = e.tag } } }
        rule E6_2_T6_InPkg { match { any p : Pkg
                any e : E6
                direct l : pkgE6 -- p.e } apply { outP : Pkg
                t : T6
                outL : pkgT6 -- outP.t } }
        rule E6_2_T6_Linked { match { any m : Model
                any p : Pkg
                any e : E6
                direct r : root -- m.p
                direct pe : pkgE6 -- p.e } apply { outM : Model
                outP : Pkg
                t : T6
                outR : root -- outM.outP
                outPe : pkgT6 -- outP.t } }
        rule E6_2_T6_Cond { match { any e : E6 where e.tag == "a" } apply { t : T6 { tag = "a" } } }
    }
    layer MapE7 {
        rule E7_2_T7 { match { any e : E7 } apply { t : T7 } }
        rule E7_2_T7_Tagged { match { any e : E7 where e.tag != "" } apply { t : T7 { tag = e.tag } } }
        rule E7_2_T7_InPkg { match { any p : Pkg
                any e : E7
