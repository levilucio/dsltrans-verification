                direct r : root -- m.p
                direct pe : pkgE8 -- p.e } apply { outM : Model
                outP : Pkg
                t : T8
                outR : root -- outM.outP
                outPe : pkgT8 -- outP.t } }
        rule E8_2_T8_Cond { match { any e : E8 where e.tag == "a" } apply { t : T8 { tag = "a" } } }
    }
    layer MapE9 {
        rule E9_2_T9 { match { any e : E9 } apply { t : T9 } }
        rule E9_2_T9_Tagged { match { any e : E9 where e.tag != "" } apply { t : T9 { tag = e.tag } } }
        rule E9_2_T9_InPkg { match { any p : Pkg
                any e : E9
                direct l : pkgE9 -- p.e } apply { outP : Pkg
                t : T9
                outL : pkgT9 -- outP.t } }
        rule E9_2_T9_Linked { match { any m : Model
                any p : Pkg
                any e : E9
                direct r : root -- m.p
                direct pe : pkgE9 -- p.e } apply { outM : Model
                outP : Pkg
                t : T9
                outR : root -- outM.outP
                outPe : pkgT9 -- outP.t } }
        rule E9_2_T9_Cond { match { any e : E9 where e.tag == "a" } apply { t : T9 { tag = "a" } } }
    }
    layer MapE10 {
        rule E10_2_T10 { match { any e : E10 } apply { t : T10 } }
        rule E10_2_T10_Tagged { match { any e : E10 where e.tag != "" } apply { t : T10 { tag = e.tag } } }
        rule E10_2_T10_InPkg { match { any p : Pkg
                any e : E10
                direct l : pkgE10 -- p.e } apply { outP : Pkg
                t : T10
                outL : pkgT10 -- outP.t } }
        rule E10_2_T10_Linked { match { any m : Model
                any p : Pkg
                any e : E10
                direct r : root -- m.p
                direct pe : pkgE10 -- p.e } apply { outM : Model
                outP : Pkg
                t : T10
                outR : root -- outM.outP
                outPe : pkgT10 -- outP.t } }
        rule E10_2_T10_Cond { match { any e : E10 where e.tag == "a" } apply { t : T10 { tag = "a" } } }
