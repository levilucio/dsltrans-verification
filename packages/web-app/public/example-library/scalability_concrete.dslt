// =============================================================================
// Scalability Fragment - 60+ rules for scalability testing
// Rules: 67
// =============================================================================
// Source/target metamodels with many element types (E1..E13, T1..T13).
// Each element type has 5 mapping rules (basic, tagged, in-pkg, linked, conditional).
// F-LNR compliant: finite attributes, root containment, match size <= 4 where possible.

metamodel SourceScalability {
    class Model { }
    class Pkg { name: String }
    class E1  { tag: String }
    class E2  { tag: String }
    class E3  { tag: String }
    class E4  { tag: String }
    class E5  { tag: String }
    class E6  { tag: String }
    class E7  { tag: String }
    class E8  { tag: String }
    class E9  { tag: String }
    class E10 { tag: String }
    class E11 { tag: String }
    class E12 { tag: String }
    class E13 { tag: String }
    containment assoc root: Model[1] -- Pkg[0..*]
    containment assoc pkgE1:  Pkg[1] -- E1[0..*]
    containment assoc pkgE2:  Pkg[1] -- E2[0..*]
    containment assoc pkgE3:  Pkg[1] -- E3[0..*]
    containment assoc pkgE4:  Pkg[1] -- E4[0..*]
    containment assoc pkgE5:  Pkg[1] -- E5[0..*]
    containment assoc pkgE6:  Pkg[1] -- E6[0..*]
    containment assoc pkgE7:  Pkg[1] -- E7[0..*]
    containment assoc pkgE8:  Pkg[1] -- E8[0..*]
    containment assoc pkgE9:  Pkg[1] -- E9[0..*]
    containment assoc pkgE10: Pkg[1] -- E10[0..*]
    containment assoc pkgE11: Pkg[1] -- E11[0..*]
    containment assoc pkgE12: Pkg[1] -- E12[0..*]
    containment assoc pkgE13: Pkg[1] -- E13[0..*]
}

metamodel TargetScalability {
    class Model { }
    class Pkg { name: String }
    class T1  { tag: String }
    class T2  { tag: String }
    class T3  { tag: String }
    class T4  { tag: String }
    class T5  { tag: String }
    class T6  { tag: String }
    class T7  { tag: String }
    class T8  { tag: String }
    class T9  { tag: String }
    class T10 { tag: String }
    class T11 { tag: String }
    class T12 { tag: String }
    class T13 { tag: String }
    containment assoc root: Model[1] -- Pkg[0..*]
    containment assoc pkgT1:  Pkg[1] -- T1[0..*]
    containment assoc pkgT2:  Pkg[1] -- T2[0..*]
    containment assoc pkgT3:  Pkg[1] -- T3[0..*]
    containment assoc pkgT4:  Pkg[1] -- T4[0..*]
    containment assoc pkgT5:  Pkg[1] -- T5[0..*]
    containment assoc pkgT6:  Pkg[1] -- T6[0..*]
    containment assoc pkgT7:  Pkg[1] -- T7[0..*]
    containment assoc pkgT8:  Pkg[1] -- T8[0..*]
    containment assoc pkgT9:  Pkg[1] -- T9[0..*]
    containment assoc pkgT10: Pkg[1] -- T10[0..*]
    containment assoc pkgT11: Pkg[1] -- T11[0..*]
    containment assoc pkgT12: Pkg[1] -- T12[0..*]
    containment assoc pkgT13: Pkg[1] -- T13[0..*]
}

transformation Scalability_concrete : SourceScalability -> TargetScalability {

    layer Root {
        rule CreateRoot {
            match { any m : Model }
            apply { outM : Model }
        }
        rule Pkg2Pkg {
            match {
                any m : Model
                any p : Pkg
                direct r : root -- m.p
            }
            apply {
                outM : Model
                outP : Pkg { name = p.name }
                outR : root -- outM.outP
            }
        }
    }

    layer MapE1 {
        rule E1_2_T1 { match { any e : E1 } apply { t : T1 } }
        rule E1_2_T1_Tagged { match { any e : E1 where e.tag != "" } apply { t : T1 { tag = e.tag } } }
        rule E1_2_T1_InPkg {
            match {
                any p : Pkg
                any e : E1
                direct l : pkgE1 -- p.e
            }
            apply {
                outP : Pkg
                t : T1
                outL : pkgT1 -- outP.t
            }
        }
        rule E1_2_T1_Linked {
            match {
                any m : Model
                any p : Pkg
                any e : E1
                direct r : root -- m.p
                direct pe : pkgE1 -- p.e
            }
            apply {
                outM : Model
                outP : Pkg
                t : T1
                outR : root -- outM.outP
                outPe : pkgT1 -- outP.t
            }
        }
        rule E1_2_T1_Cond { match { any e : E1 where e.tag == "a" } apply { t : T1 { tag = "a" } } }
    }
    layer MapE2 {
        rule E2_2_T2 { match { any e : E2 } apply { t : T2 } }
        rule E2_2_T2_Tagged { match { any e : E2 where e.tag != "" } apply { t : T2 { tag = e.tag } } }
        rule E2_2_T2_InPkg {
            match {
                any p : Pkg
                any e : E2
                direct l : pkgE2 -- p.e
            }
            apply {
                outP : Pkg
                t : T2
                outL : pkgT2 -- outP.t
            }
        }
        rule E2_2_T2_Linked {
            match {
                any m : Model
                any p : Pkg
                any e : E2
                direct r : root -- m.p
                direct pe : pkgE2 -- p.e
            }
            apply {
                outM : Model
                outP : Pkg
                t : T2
                outR : root -- outM.outP
                outPe : pkgT2 -- outP.t
            }
        }
        rule E2_2_T2_Cond { match { any e : E2 where e.tag == "a" } apply { t : T2 { tag = "a" } } }
    }
    layer MapE3 {
        rule E3_2_T3 { match { any e : E3 } apply { t : T3 } }
        rule E3_2_T3_Tagged { match { any e : E3 where e.tag != "" } apply { t : T3 { tag = e.tag } } }
        rule E3_2_T3_InPkg {
            match {
                any p : Pkg
                any e : E3
                direct l : pkgE3 -- p.e
            }
            apply {
                outP : Pkg
                t : T3
                outL : pkgT3 -- outP.t
            }
        }
        rule E3_2_T3_Linked {
            match {
                any m : Model
                any p : Pkg
                any e : E3
                direct r : root -- m.p
                direct pe : pkgE3 -- p.e
            }
            apply {
                outM : Model
                outP : Pkg
                t : T3
                outR : root -- outM.outP
                outPe : pkgT3 -- outP.t
            }
        }
        rule E3_2_T3_Cond { match { any e : E3 where e.tag == "a" } apply { t : T3 { tag = "a" } } }
    }
    layer MapE4 {
        rule E4_2_T4 { match { any e : E4 } apply { t : T4 } }
        rule E4_2_T4_Tagged { match { any e : E4 where e.tag != "" } apply { t : T4 { tag = e.tag } } }
        rule E4_2_T4_InPkg {
