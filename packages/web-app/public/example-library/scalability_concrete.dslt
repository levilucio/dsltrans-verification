    layer MapE11 {
        rule E11_2_T11 { match { any e : E11 } apply { t : T11 } }
        rule E11_2_T11_Tagged { match { any e : E11 where e.tag != "" } apply { t : T11 { tag = e.tag } } }
        rule E11_2_T11_InPkg { match { any p : Pkg
