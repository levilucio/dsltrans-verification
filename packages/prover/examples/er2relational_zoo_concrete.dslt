// Expected to FAIL
property NodeMapsToTargetEdge_ShouldFail {
    precondition {
        any sm : ERModel
        any sn : Entity
        direct l1 : nodes -- sm.sn
    }
    postcondition {
        te : ForeignKey
        te <--trace-- sn
    }
}

