property IfExpHasIfInstr {
    precondition {
        any op : Operation
        any e : IfExp
        direct owns : exprs -- op.e
    }
    postcondition {
        e_op : Operation
        i : IfInstr
        outL : e_instrs -- e_op.i
        e_op <--trace-- op
        i <--trace-- e
    }
}

property OperationWithBodyHasTracedTargetOperation {
    precondition {
        any op : Operation
        any e : Expr
        direct b : body -- op.e
    }
    postcondition {
        e_op : Operation
        e_op <--trace-- op
    }
}

property ParameterTracedToLocalVariable_ShouldFail {
    precondition {
        any op : Operation
        any p : Parameter
        direct l : params -- op.p
    }
    postcondition {
        e_l : LocalVariable
        e_l <--trace-- p
    }
}

property FieldTracedToOperation_ShouldFail {
    precondition {
        any mod : Module
        any f : Field
        direct l : fields -- mod.f
    }
    postcondition {
        e_op : Operation
        e_op <--trace-- f
    }
}

property VariableExpHasPushInt_ShouldFail {
    precondition {
        any op : Operation
        any e : VariableExp
        direct owns : exprs -- op.e
    }
    postcondition {
        i : PushInt
        i <--trace-- e
    }
}

property BuiltInNotHasGet_ShouldFail {
    precondition {
        any op : Operation
        any c : BuiltInCall where c.opName == "not"
        direct owns : exprs -- op.c
    }
    postcondition {
        i : Get
        i <--trace-- c
    }
}

property IfExpHasPushSeq_ShouldFail {
    precondition {
        any op : Operation
        any e : IfExp
        direct owns : exprs -- op.e
    }
    postcondition {
        i : PushSeq
        i <--trace-- e
    }
}
