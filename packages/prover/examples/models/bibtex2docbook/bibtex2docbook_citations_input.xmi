<?xml version="1.0" encoding="UTF-8"?>
<model xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <objects xmi:id="model1" xsi:type="BibTeX:Model"/>
  <objects xmi:id="bib1" xsi:type="BibTeX:BibFile"/>

  <objects xmi:id="artA" xsi:type="BibTeX:Article" key="k1" year="2021"/>
  <objects xmi:id="artB" xsi:type="BibTeX:Article" key="k2" year="2020"/>
  <objects xmi:id="book1" xsi:type="BibTeX:Book" key="k3" year="1999"/>

  <objects xmi:id="a1" xsi:type="BibTeX:Author" name="a1"/>
  <objects xmi:id="a2" xsi:type="BibTeX:Author" name="a2"/>
  <objects xmi:id="kw1" xsi:type="BibTeX:Keyword" text="kw1"/>

  <links xsi:type="BibTeX:root" source="model1" target="bib1"/>
  <links xsi:type="BibTeX:entries" source="bib1" target="artA"/>
  <links xsi:type="BibTeX:entries" source="bib1" target="artB"/>
  <links xsi:type="BibTeX:entries" source="bib1" target="book1"/>

  <links xsi:type="BibTeX:authors" source="artA" target="a1"/>
  <links xsi:type="BibTeX:authors" source="artB" target="a2"/>
  <links xsi:type="BibTeX:authors" source="book1" target="a1"/>

  <links xsi:type="BibTeX:keywords" source="artA" target="kw1"/>
  <links xsi:type="BibTeX:keywords" source="artB" target="kw1"/>

  <links xsi:type="BibTeX:cites" source="artA" target="artB"/>
  <links xsi:type="BibTeX:cites" source="artB" target="book1"/>
</model>
