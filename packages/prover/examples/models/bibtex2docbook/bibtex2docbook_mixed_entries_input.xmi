<?xml version="1.0" encoding="UTF-8"?>
<model xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <objects xmi:id="model1" xsi:type="BibTeX:Model"/>
  <objects xmi:id="bib1" xsi:type="BibTeX:BibFile"/>

  <objects xmi:id="art1" xsi:type="BibTeX:Article" key="k1" year="2018"/>
  <objects xmi:id="book1" xsi:type="BibTeX:Book" key="k2" year="2004"/>
  <objects xmi:id="proc1" xsi:type="BibTeX:InProceedings" key="k3" year="2012"/>

  <objects xmi:id="a1" xsi:type="BibTeX:Author" name="a1"/>
  <objects xmi:id="a2" xsi:type="BibTeX:Author" name="a2"/>
  <objects xmi:id="a3" xsi:type="BibTeX:Author" name="a3"/>

  <objects xmi:id="kw1" xsi:type="BibTeX:Keyword" text="kw1"/>
  <objects xmi:id="kw2" xsi:type="BibTeX:Keyword" text="kw2"/>

  <links xsi:type="BibTeX:root" source="model1" target="bib1"/>
  <links xsi:type="BibTeX:entries" source="bib1" target="art1"/>
  <links xsi:type="BibTeX:entries" source="bib1" target="book1"/>
  <links xsi:type="BibTeX:entries" source="bib1" target="proc1"/>

  <links xsi:type="BibTeX:authors" source="art1" target="a1"/>
  <links xsi:type="BibTeX:authors" source="art1" target="a2"/>
  <links xsi:type="BibTeX:authors" source="book1" target="a3"/>
  <links xsi:type="BibTeX:authors" source="proc1" target="a2"/>

  <links xsi:type="BibTeX:keywords" source="art1" target="kw1"/>
  <links xsi:type="BibTeX:keywords" source="book1" target="kw2"/>
  <links xsi:type="BibTeX:keywords" source="proc1" target="kw1"/>

  <links xsi:type="BibTeX:cites" source="art1" target="book1"/>
  <links xsi:type="BibTeX:cites" source="art1" target="proc1"/>
</model>
