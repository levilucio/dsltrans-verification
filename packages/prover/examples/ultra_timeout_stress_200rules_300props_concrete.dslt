// Expected to HOLD
property UModelMaps { precondition { any m : UModel } postcondition { tm : TUModel tm <--trace-- m } }
property N1Maps { precondition { any n : N1 } postcondition { tn : TN1 tn <--trace-- n } }
property N2Maps { precondition { any n : N2 } postcondition { tn : TN2 tn <--trace-- n } }
property N3Maps { precondition { any n : N3 } postcondition { tn : TN3 tn <--trace-- n } }
property N4Maps { precondition { any n : N4 } postcondition { tn : TN4 tn <--trace-- n } }
property HubMaps { precondition { any h : Hub } postcondition { th : THub th <--trace-- h } }
property E12Maps { precondition { any e : E12 } postcondition { te : TL12 te <--trace-- e } }
property E23Maps { precondition { any e : E23 } postcondition { te : TL23 te <--trace-- e } }
property E34Maps { precondition { any e : E34 } postcondition { te : TL34 te <--trace-- e } }
property E41Maps { precondition { any e : E41 } postcondition { te : TL41 te <--trace-- e } }
property E13Maps { precondition { any e : E13 } postcondition { te : TL13 te <--trace-- e } }
property E24Maps { precondition { any e : E24 } postcondition { te : TL24 te <--trace-- e } }
property E12Connectivity { precondition { any e : E12 any s : N1 any d : N2 direct sl : e12Src -- e.s direct dl : e12Dst -- e.d } postcondition { te : TL12 ts : TN1 td : TN2 a : tl12Src -- te.ts b : tl12Dst -- te.td te <--trace-- e ts <--trace-- s td <--trace-- d } }
property E23Connectivity { precondition { any e : E23 any s : N2 any d : N3 direct sl : e23Src -- e.s direct dl : e23Dst -- e.d } postcondition { te : TL23 ts : TN2 td : TN3 a : tl23Src -- te.ts b : tl23Dst -- te.td te <--trace-- e ts <--trace-- s td <--trace-- d } }
property E34Connectivity { precondition { any e : E34 any s : N3 any d : N4 direct sl : e34Src -- e.s direct dl : e34Dst -- e.d } postcondition { te : TL34 ts : TN3 td : TN4 a : tl34Src -- te.ts b : tl34Dst -- te.td te <--trace-- e ts <--trace-- s td <--trace-- d } }
property E41Connectivity { precondition { any e : E41 any s : N4 any d : N1 direct sl : e41Src -- e.s direct dl : e41Dst -- e.d } postcondition { te : TL41 ts : TN4 td : TN1 a : tl41Src -- te.ts b : tl41Dst -- te.td te <--trace-- e ts <--trace-- s td <--trace-- d } }
property HubN1Connectivity { precondition { any a : Attachment any h : Hub any n : N1 direct hL : attHub -- a.h direct nL : attN1 -- a.n } postcondition { th : THub tn : TN1 l : hubN1 -- th.tn th <--trace-- h tn <--trace-- n } }
property HubN2Connectivity { precondition { any a : Attachment any h : Hub any n : N2 direct hL : attHub -- a.h direct nL : attN2 -- a.n } postcondition { th : THub tn : TN2 l : hubN2 -- th.tn th <--trace-- h tn <--trace-- n } }
property HubN3Connectivity { precondition { any a : Attachment any h : Hub any n : N3 direct hL : attHub -- a.h direct nL : attN3 -- a.n } postcondition { th : THub tn : TN3 l : hubN3 -- th.tn th <--trace-- h tn <--trace-- n } }
property HubN4Connectivity { precondition { any a : Attachment any h : Hub any n : N4 direct hL : attHub -- a.h direct nL : attN4 -- a.n } postcondition { th : THub tn : TN4 l : hubN4 -- th.tn th <--trace-- h tn <--trace-- n } }
property UMarker001FromN1 {
    precondition {
        any m : UModel
        any n : N1 where n.flag == true
        any p : N2
        any e : E12
        any h : Hub
        direct dp : n2Nodes -- m.p
        direct de : e12Edges -- m.e
        direct dh : hubs -- m.h
        direct l : n1Nodes -- m.n
        direct es : e12Src -- e.n
        direct ed : e12Dst -- e.p
    }
    postcondition {
        mk : UMarker001
        mk <--trace-- n
    }
}
property UMarker002FromN2 {
    precondition {
        any m : UModel
        any n : N2 where n.level >= 2
