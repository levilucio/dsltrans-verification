    containment assoc tn1Nodes : TUModel[1] -- TN1[0..*]
    containment assoc tn2Nodes : TUModel[1] -- TN2[0..*]
    containment assoc tn3Nodes : TUModel[1] -- TN3[0..*]
    containment assoc tn4Nodes : TUModel[1] -- TN4[0..*]
    containment assoc thubs : TUModel[1] -- THub[0..*]
    containment assoc tl12Edges : TUModel[1] -- TL12[0..*]
    containment assoc tl23Edges : TUModel[1] -- TL23[0..*]
    containment assoc tl34Edges : TUModel[1] -- TL34[0..*]
    containment assoc tl41Edges : TUModel[1] -- TL41[0..*]
    containment assoc tl13Edges : TUModel[1] -- TL13[0..*]
    containment assoc tl24Edges : TUModel[1] -- TL24[0..*]
    containment assoc umarkers : TUModel[1] -- UMarker[0..*]

    assoc tl12Src : TL12[0..*] -- TN1[1]
    assoc tl12Dst : TL12[0..*] -- TN2[1]
    assoc tl23Src : TL23[0..*] -- TN2[1]
    assoc tl23Dst : TL23[0..*] -- TN3[1]
    assoc tl34Src : TL34[0..*] -- TN3[1]
    assoc tl34Dst : TL34[0..*] -- TN4[1]
