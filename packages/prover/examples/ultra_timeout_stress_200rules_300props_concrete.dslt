metamodel UltraSource {
    enum Kind { K0, K1, K2 }
    class UModel { }
    class N1 { flag: Bool level: Int kind: Kind }
    class N2 { flag: Bool level: Int kind: Kind }
    class N3 { flag: Bool level: Int kind: Kind }
    class N4 { flag: Bool level: Int kind: Kind }
    class Hub { flag: Bool level: Int }
    class E12 { weight: Int }
    class E23 { weight: Int }
    class E34 { weight: Int }
    class E41 { weight: Int }
    class E13 { weight: Int }
    class E24 { weight: Int }
    class Attachment { strength: Int }

    containment assoc n1Nodes : UModel[1] -- N1[0..*]
    containment assoc n2Nodes : UModel[1] -- N2[0..*]
    containment assoc n3Nodes : UModel[1] -- N3[0..*]
    containment assoc n4Nodes : UModel[1] -- N4[0..*]
    containment assoc hubs : UModel[1] -- Hub[0..*]
    containment assoc e12Edges : UModel[1] -- E12[0..*]
    containment assoc e23Edges : UModel[1] -- E23[0..*]
    containment assoc e34Edges : UModel[1] -- E34[0..*]
    containment assoc e41Edges : UModel[1] -- E41[0..*]
    containment assoc e13Edges : UModel[1] -- E13[0..*]
    containment assoc e24Edges : UModel[1] -- E24[0..*]
    containment assoc attachments : UModel[1] -- Attachment[0..*]

    assoc e12Src : E12[0..*] -- N1[1]
    assoc e12Dst : E12[0..*] -- N2[1]
    assoc e23Src : E23[0..*] -- N2[1]
    assoc e23Dst : E23[0..*] -- N3[1]
    assoc e34Src : E34[0..*] -- N3[1]
    assoc e34Dst : E34[0..*] -- N4[1]
    assoc e41Src : E41[0..*] -- N4[1]
    assoc e41Dst : E41[0..*] -- N1[1]
    assoc e13Src : E13[0..*] -- N1[1]
    assoc e13Dst : E13[0..*] -- N3[1]
    assoc e24Src : E24[0..*] -- N2[1]
    assoc e24Dst : E24[0..*] -- N4[1]

    assoc attHub : Attachment[0..*] -- Hub[1]
    assoc attN1 : Attachment[0..*] -- N1[0..1]
    assoc attN2 : Attachment[0..*] -- N2[0..1]
    assoc attN3 : Attachment[0..*] -- N3[0..1]
    assoc attN4 : Attachment[0..*] -- N4[0..1]
}

