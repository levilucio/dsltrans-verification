    assoc tl24Dst : TL24[0..*] -- TN4[1]

    assoc hubN1 : THub[0..*] -- TN1[0..*]
    assoc hubN2 : THub[0..*] -- TN2[0..*]
    assoc hubN3 : THub[0..*] -- TN3[0..*]
    assoc hubN4 : THub[0..*] -- TN4[0..*]

    assoc umN1 : UMarker[0..*] -- TN1[0..1]
    assoc umN2 : UMarker[0..*] -- TN2[0..1]
    assoc umN3 : UMarker[0..*] -- TN3[0..1]
    assoc umN4 : UMarker[0..*] -- TN4[0..1]
}

transformation UltraStressTransform : UltraSource -> UltraTarget {
    layer L1_Create {
        rule Model2TUModel { match { any m : UModel } apply { tm : TUModel } }
        rule N12TN1 { match { any n : N1 } apply { tn : TN1 } }
        rule N22TN2 { match { any n : N2 } apply { tn : TN2 } }
        rule N32TN3 { match { any n : N3 } apply { tn : TN3 } }
        rule N42TN4 { match { any n : N4 } apply { tn : TN4 } }
        rule Hub2THub { match { any h : Hub } apply { th : THub } }
        rule E122TL12 { match { any e : E12 } apply { te : TL12 } }
        rule E232TL23 { match { any e : E23 } apply { te : TL23 } }
        rule E342TL34 { match { any e : E34 } apply { te : TL34 } }
        rule E412TL41 { match { any e : E41 } apply { te : TL41 } }
        rule E132TL13 { match { any e : E13 } apply { te : TL13 } }
        rule E242TL24 { match { any e : E24 } apply { te : TL24 } }
    }

    layer L2_Connect {
        rule ConnectN1InModel {
            match { any m : UModel any n : N1 direct l : n1Nodes -- m.n }
            apply { tm : TUModel tn : TN1 o : tn1Nodes -- tm.tn }
            backward { tm <--trace-- m tn <--trace-- n }
        }
        rule ConnectN2InModel {
            match { any m : UModel any n : N2 direct l : n2Nodes -- m.n }
            apply { tm : TUModel tn : TN2 o : tn2Nodes -- tm.tn }
            backward { tm <--trace-- m tn <--trace-- n }
        }
        rule ConnectN3InModel {
            match { any m : UModel any n : N3 direct l : n3Nodes -- m.n }
            apply { tm : TUModel tn : TN3 o : tn3Nodes -- tm.tn }
            backward { tm <--trace-- m tn <--trace-- n }
        }
        rule ConnectN4InModel {
            match { any m : UModel any n : N4 direct l : n4Nodes -- m.n }
            apply { tm : TUModel tn : TN4 o : tn4Nodes -- tm.tn }
            backward { tm <--trace-- m tn <--trace-- n }
        }
        rule ConnectHubInModel {
            match { any m : UModel any h : Hub direct l : hubs -- m.h }
            apply { tm : TUModel th : THub o : thubs -- tm.th }
            backward { tm <--trace-- m th <--trace-- h }
        }
        rule ConnectE12 {
            match { any m : UModel any e : E12 any s : N1 any d : N2 direct el : e12Edges -- m.e direct sl : e12Src -- e.s direct dl : e12Dst -- e.d }
            apply { tm : TUModel te : TL12 ts : TN1 td : TN2 o1 : tl12Edges -- tm.te o2 : tl12Src -- te.ts o3 : tl12Dst -- te.td }
            backward { tm <--trace-- m te <--trace-- e ts <--trace-- s td <--trace-- d }
        }
        rule ConnectE23 {
            match { any m : UModel any e : E23 any s : N2 any d : N3 direct el : e23Edges -- m.e direct sl : e23Src -- e.s direct dl : e23Dst -- e.d }
            apply { tm : TUModel te : TL23 ts : TN2 td : TN3 o1 : tl23Edges -- tm.te o2 : tl23Src -- te.ts o3 : tl23Dst -- te.td }
            backward { tm <--trace-- m te <--trace-- e ts <--trace-- s td <--trace-- d }
        }
        rule ConnectE34 {
            match { any m : UModel any e : E34 any s : N3 any d : N4 direct el : e34Edges -- m.e direct sl : e34Src -- e.s direct dl : e34Dst -- e.d }
            apply { tm : TUModel te : TL34 ts : TN3 td : TN4 o1 : tl34Edges -- tm.te o2 : tl34Src -- te.ts o3 : tl34Dst -- te.td }
            backward { tm <--trace-- m te <--trace-- e ts <--trace-- s td <--trace-- d }
        }
        rule ConnectE41 {
            match { any m : UModel any e : E41 any s : N4 any d : N1 direct el : e41Edges -- m.e direct sl : e41Src -- e.s direct dl : e41Dst -- e.d }
            apply { tm : TUModel te : TL41 ts : TN4 td : TN1 o1 : tl41Edges -- tm.te o2 : tl41Src -- te.ts o3 : tl41Dst -- te.td }
            backward { tm <--trace-- m te <--trace-- e ts <--trace-- s td <--trace-- d }
        }
        rule ConnectE13 {
            match { any m : UModel any e : E13 any s : N1 any d : N3 direct el : e13Edges -- m.e direct sl : e13Src -- e.s direct dl : e13Dst -- e.d }
            apply { tm : TUModel te : TL13 ts : TN1 td : TN3 o1 : tl13Edges -- tm.te o2 : tl13Src -- te.ts o3 : tl13Dst -- te.td }
            backward { tm <--trace-- m te <--trace-- e ts <--trace-- s td <--trace-- d }
        }
        rule ConnectE24 {
            match { any m : UModel any e : E24 any s : N2 any d : N4 direct el : e24Edges -- m.e direct sl : e24Src -- e.s direct dl : e24Dst -- e.d }
            apply { tm : TUModel te : TL24 ts : TN2 td : TN4 o1 : tl24Edges -- tm.te o2 : tl24Src -- te.ts o3 : tl24Dst -- te.td }
            backward { tm <--trace-- m te <--trace-- e ts <--trace-- s td <--trace-- d }
        }
        rule ConnectHubN1 {
            match { any a : Attachment any h : Hub any n : N1 direct hL : attHub -- a.h direct nL : attN1 -- a.n }
            apply { th : THub tn : TN1 l : hubN1 -- th.tn }
            backward { th <--trace-- h tn <--trace-- n }
        }
        rule ConnectHubN2 {
            match { any a : Attachment any h : Hub any n : N2 direct hL : attHub -- a.h direct nL : attN2 -- a.n }
            apply { th : THub tn : TN2 l : hubN2 -- th.tn }
            backward { th <--trace-- h tn <--trace-- n }
        }
        rule ConnectHubN3 {
            match { any a : Attachment any h : Hub any n : N3 direct hL : attHub -- a.h direct nL : attN3 -- a.n }
            apply { th : THub tn : TN3 l : hubN3 -- th.tn }
            backward { th <--trace-- h tn <--trace-- n }
        }
        rule ConnectHubN4 {
            match { any a : Attachment any h : Hub any n : N4 direct hL : attHub -- a.h direct nL : attN4 -- a.n }
            apply { th : THub tn : TN4 l : hubN4 -- th.tn }
            backward { th <--trace-- h tn <--trace-- n }
        }
    }

    layer L3_Markers {
        rule UMk001_N1 {
            match {
                any m : UModel
                any n : N1 where n.flag == true
                direct l : n1Nodes -- m.n
            }
            apply {
                tm : TUModel
                tn : TN1
                mk : UMarker001
                l1 : umarkers -- tm.mk
                l2 : umN1 -- mk.tn
            }
            backward {
                tm <--trace-- m
                tn <--trace-- n
            }
        }
        rule UMk002_N2 {
            match {
                any m : UModel
                any n : N2 where n.level >= 2
                direct l : n2Nodes -- m.n
            }
            apply {
                tm : TUModel
                tn : TN2
                mk : UMarker002
                l1 : umarkers -- tm.mk
                l2 : umN2 -- mk.tn
            }
            backward {
                tm <--trace-- m
                tn <--trace-- n
            }
        }
        rule UMk003_N3 {
            match {
                any m : UModel
                any n : N3 where n.kind == "K1"
                direct l : n3Nodes -- m.n
            }
            apply {
                tm : TUModel
                tn : TN3
                mk : UMarker003
                l1 : umarkers -- tm.mk
                l2 : umN3 -- mk.tn
            }
            backward {
                tm <--trace-- m
                tn <--trace-- n
            }
        }
        rule UMk004_N4 {
            match {
                any m : UModel
                any n : N4 where n.kind == "K2"
                direct l : n4Nodes -- m.n
            }
            apply {
                tm : TUModel
                tn : TN4
                mk : UMarker004
                l1 : umarkers -- tm.mk
                l2 : umN4 -- mk.tn
            }
            backward {
                tm <--trace-- m
                tn <--trace-- n
            }
        }
        rule UMk005_N1 {
            match {
                any m : UModel
                any n : N1 where n.flag == false
                direct l : n1Nodes -- m.n
            }
            apply {
                tm : TUModel
                tn : TN1
                mk : UMarker005
                l1 : umarkers -- tm.mk
                l2 : umN1 -- mk.tn
            }
            backward {
                tm <--trace-- m
                tn <--trace-- n
            }
        }
        rule UMk006_N2 {
            match {
                any m : UModel
                any n : N2
                direct l : n2Nodes -- m.n
            }
            apply {
                tm : TUModel
                tn : TN2
                mk : UMarker006
                l1 : umarkers -- tm.mk
                l2 : umN2 -- mk.tn
            }
            backward {
                tm <--trace-- m
                tn <--trace-- n
            }
        }
        rule UMk007_N3 {
            match {
                any m : UModel
                any n : N3 where n.flag == true
                direct l : n3Nodes -- m.n
            }
            apply {
                tm : TUModel
                tn : TN3
                mk : UMarker007
                l1 : umarkers -- tm.mk
                l2 : umN3 -- mk.tn
            }
            backward {
                tm <--trace-- m
                tn <--trace-- n
            }
        }
        rule UMk008_N4 {
            match {
                any m : UModel
                any n : N4 where n.level >= 2
                direct l : n4Nodes -- m.n
            }
            apply {
                tm : TUModel
                tn : TN4
                mk : UMarker008
                l1 : umarkers -- tm.mk
                l2 : umN4 -- mk.tn
            }
            backward {
                tm <--trace-- m
                tn <--trace-- n
            }
        }
        rule UMk009_N1 {
            match {
                any m : UModel
                any n : N1 where n.kind == "K1"
                direct l : n1Nodes -- m.n
            }
            apply {
                tm : TUModel
                tn : TN1
                mk : UMarker009
                l1 : umarkers -- tm.mk
                l2 : umN1 -- mk.tn
            }
            backward {
                tm <--trace-- m
                tn <--trace-- n
            }
        }
        rule UMk010_N2 {
            match {
                any m : UModel
                any n : N2 where n.kind == "K2"
                direct l : n2Nodes -- m.n
            }
            apply {
                tm : TUModel
                tn : TN2
                mk : UMarker010
                l1 : umarkers -- tm.mk
                l2 : umN2 -- mk.tn
            }
            backward {
                tm <--trace-- m
                tn <--trace-- n
            }
        }
        rule UMk011_N3 {
            match {
                any m : UModel
                any n : N3 where n.flag == false
                direct l : n3Nodes -- m.n
            }
            apply {
                tm : TUModel
                tn : TN3
                mk : UMarker011
                l1 : umarkers -- tm.mk
                l2 : umN3 -- mk.tn
            }
            backward {
                tm <--trace-- m
                tn <--trace-- n
            }
        }
        rule UMk012_N4 {
            match {
                any m : UModel
                any n : N4
                direct l : n4Nodes -- m.n
            }
            apply {
                tm : TUModel
                tn : TN4
                mk : UMarker012
                l1 : umarkers -- tm.mk
                l2 : umN4 -- mk.tn
            }
            backward {
                tm <--trace-- m
                tn <--trace-- n
            }
        }
        rule UMk013_N1 {
            match {
                any m : UModel
                any n : N1 where n.flag == true
                direct l : n1Nodes -- m.n
            }
            apply {
                tm : TUModel
                tn : TN1
                mk : UMarker013
                l1 : umarkers -- tm.mk
                l2 : umN1 -- mk.tn
            }
            backward {
                tm <--trace-- m
                tn <--trace-- n
            }
        }
        rule UMk014_N2 {
            match {
                any m : UModel
                any n : N2 where n.level >= 2
                direct l : n2Nodes -- m.n
            }
            apply {
                tm : TUModel
                tn : TN2
                mk : UMarker014
                l1 : umarkers -- tm.mk
                l2 : umN2 -- mk.tn
            }
            backward {
                tm <--trace-- m
                tn <--trace-- n
            }
        }
        rule UMk015_N3 {
            match {
                any m : UModel
                any n : N3 where n.kind == "K1"
                direct l : n3Nodes -- m.n
            }
            apply {
                tm : TUModel
                tn : TN3
                mk : UMarker015
